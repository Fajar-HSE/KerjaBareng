generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
}

enum TaskStatus {
  pending
  in_progress
  done
  overdue
}

enum TargetType {
  daily
  weekly
}

enum NotificationType {
  deadline
  mention
  assignment
}

model Profile {
  id                  String    @id @default(uuid())
  email               String    @unique
  fullName            String
  passwordHash        String
  role                Role      @default(user)
  division            String?
  avatarUrl           String?
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?   @unique
  emailVerifyExpires  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  assignedTasks Task[]         @relation("AssignedTo")
  createdTasks  Task[]         @relation("AssignedBy")
  progresses    TaskProgress[]
  messagesSent  ChatMessage[]  @relation("Sender")
  messagesRecvd ChatMessage[]  @relation("Receiver")
  notifications Notification[]
}

model Task {
  id           String         @id @default(uuid())
  title        String
  description  String?
  assignedToId String
  assignedById String
  status       TaskStatus     @default(pending)
  deadline     DateTime
  targetType   TargetType     @default(daily)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  assignedTo   Profile        @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedBy   Profile        @relation("AssignedBy", fields: [assignedById], references: [id])
  progresses   TaskProgress[]
  messages     ChatMessage[]
}

model TaskProgress {
  id             String   @id @default(uuid())
  taskId         String
  userId         String
  progressNote   String?
  attachmentUrls String[]
  isChecklist    Boolean  @default(false)
  createdAt      DateTime @default(now())

  task Task    @relation(fields: [taskId], references: [id])
  user Profile @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id            String   @id @default(uuid())
  taskId        String?
  senderId      String
  receiverId    String
  message       String
  attachmentUrl String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  task     Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  sender   Profile @relation("Sender", fields: [senderId], references: [id])
  receiver Profile @relation("Receiver", fields: [receiverId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user Profile @relation(fields: [userId], references: [id])
}
